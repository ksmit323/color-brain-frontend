---
/**
 * Floating glass navigation pill. Middle links collapse away on small screens
 * (the page is a single scroll — the CTAs are what matter on mobile).
 */
---

<header class="nav">
  <div class="container nav__inner">
    <a class="nav__brand" href="#top">
      <img src="/cb_logo.svg" alt="" width="26" height="27" />
      <span>Color Brain</span>
      <em>AI</em>
    </a>
    <nav class="nav__links" aria-label="Sections">
      <a href="#how-it-works">How It Works</a>
      <a href="#proof">Proof</a>
      <a href="#case-studies">Case Studies</a>
      <a href="#who-its-for">Who It's For</a>
    </nav>
    <div class="nav__actions">
      <a class="nav__ghost" href="https://app.colorbrain.co">Open the App</a>
      <a class="btn btn--primary nav__cta" href="#contact">Request a Pilot</a>
    </div>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0.75rem;
    z-index: 10;
    margin-inline: max(0.75rem, calc((100vw - var(--container)) / 2));
    border: 1px solid color-mix(in srgb, var(--holo) 14%, rgba(41, 46, 58, 0.66));
    border-radius: 999px;
    background: color-mix(in srgb, var(--bg) 68%, transparent);
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    box-shadow:
      0 14px 42px rgba(0, 0, 0, 0.38),
      inset 0 1px 0 rgba(127, 216, 232, 0.07);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    height: 4rem;
  }

  .nav__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-display);
    font-weight: 600;
    text-decoration: none;
  }

  .nav__brand img {
    filter: drop-shadow(0 0 12px rgba(237, 238, 244, 0.14));
  }

  .nav__brand em {
    padding: 0.22em 0.42em;
    border: 1px solid var(--line);
    border-radius: 3px;
    font-family: var(--font-mono);
    font-size: 0.53rem;
    font-style: normal;
    letter-spacing: 0.12em;
    color: var(--ink-faint);
  }

  .nav__links {
    display: flex;
    gap: 1.75rem;
  }

  .nav__links a {
    position: relative;
    font-size: 0.9rem;
    color: var(--ink-dim);
    text-decoration: none;
    transition:
      color 160ms ease,
      text-shadow 160ms ease;
  }

  /* Terminal-style cursor on hover; absolute so siblings never shift. */
  .nav__links a::before {
    content: ">";
    position: absolute;
    left: -0.85em;
    font-family: var(--font-mono);
    font-size: 0.8em;
    color: var(--holo);
    opacity: 0;
    transform: translateX(-3px);
    transition:
      opacity 160ms ease,
      transform 160ms ease;
  }

  .nav__links a:hover {
    color: var(--ink);
    text-shadow: 0 0 14px rgba(127, 216, 232, 0.35);
  }

  .nav__links a:hover::before {
    opacity: 1;
    transform: none;
  }

  .nav__actions {
    display: flex;
    align-items: center;
    gap: 1.1rem;
  }

  .nav__ghost {
    font-size: 0.9rem;
    color: var(--ink-dim);
    text-decoration: none;
  }

  .nav__ghost:hover {
    color: var(--ink);
  }

  .nav__cta {
    min-height: 2.35rem;
    padding: 0.5em 1.1em;
    font-size: 0.67rem;
  }

  @media (max-width: 860px) {
    .nav__links,
    .nav__ghost {
      display: none;
    }

    /* The pill's margins + border cost ~26px; reclaim them so the brand and
       CTA still fit on one line. */
    .nav {
      margin-inline: 0.5rem;
    }

    .nav__inner {
      gap: 0.9rem;
      padding-inline: 0.9rem;
    }

    .nav__brand span,
    .nav__cta {
      white-space: nowrap;
    }
  }
</style>
