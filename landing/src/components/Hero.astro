---
/**
 * Hero: the page's thesis. Copy sits on the left; the dye-history brain
 * (or its poster fallback) fills the stage behind it. The headline is the
 * LCP element — it never waits on fonts from the network or WebGL.
 */
---

<section class="hero" id="hero">
  <div class="hero__scrim"></div>
  <div class="container hero__inner">
    <p class="eyebrow">12,398 dye jobs · CIELAB · D65</p>
    <h1 class="hero__headline" data-split>The recipe already exists. We find it.</h1>
    <p class="hero__subhead">
      Color Brain plots your factory's entire dye history in color space,
      matches every new target to a recipe you've already proven — and stays
      silent when it isn't sure.
    </p>
    <div class="hero__actions">
      <a class="btn btn--primary" href="#contact">Request a Pilot</a>
      <a class="btn btn--ghost" href="https://app.colorbrain.co">Open the App</a>
    </div>
    <dl class="hero__metrics">
      <div class="hero__metric">
        <dt class="readout__value">86.7%</dt>
        <dd class="readout__label">win rate on recommendations</dd>
      </div>
      <div class="hero__metric">
        <dt class="readout__value">2,043</dt>
        <dd class="readout__label">unseen holdout jobs</dd>
      </div>
    </dl>
  </div>
  <p class="hero__cue" aria-hidden="true">scroll — watch it search</p>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
  }

  /* Keeps left-side copy legible while the constellation bleeds in from the right. */
  .hero__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      100deg,
      rgba(10, 11, 16, 0.92) 30%,
      rgba(10, 11, 16, 0.45) 60%,
      rgba(10, 11, 16, 0.05) 100%
    );
  }

  .hero__inner {
    position: relative;
    width: 100%;
    padding-block: 7rem;
  }

  .hero__headline {
    font-size: var(--text-hero);
    /* em, not ch: ch depends on the loaded font, so a ch-based box re-wraps
       when the webfont swaps in — the one layout shift on this page. */
    max-width: 9.3em;
    margin-top: 1.5rem;
  }

  .hero__subhead {
    font-size: var(--text-lede);
    color: var(--ink-dim);
    max-width: 28em; /* em, not ch — see headline */
    margin-top: 1.5rem;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 2.25rem;
  }

  .hero__metrics {
    display: flex;
    flex-wrap: wrap;
    gap: 3rem;
    margin-top: 3.5rem;
  }

  .hero__metric dd {
    margin: 0;
  }

  .hero__cue {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }
</style>
